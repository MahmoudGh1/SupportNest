// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  extensions = [vector]
}

model Organization {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  slug         String   @unique
  email        String
  widgetSecret String

  widgetConfig Json     @default("{}")

  planId       String   @db.Uuid
  plan         Pricing  @relation(fields: [planId], references: [id])

  isActive     Boolean  @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  invitations Invitation[]

  businessApiConfig  BusinessApiConfig?
  toolDefinitions    ToolDefinition[]

  users                  User[]
  apiKeys                ApiKey[]
  customers              Customer[]
  conversations          Conversation[]
  tickets                Ticket[]
  knowledgeDocuments     KnowledgeDocument[]
  documentChunks         DocumentChunk[]
  csatRatings            CsatRating[]
  conversationAnalytics  ConversationAnalytics[]
  payments               Payment[]

  @@map("organizations")
}

model User {
  id             String        @id @default(uuid()) @db.Uuid

  organizationId String?       @db.Uuid
  organization   Organization? @relation(fields: [organizationId], references: [id])

  email          String        @unique
  passwordHash   String

  role           Role

  firstName      String
  lastName       String

  isActive       Boolean       @default(true)

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  sentInvitations Invitation[] @relation("SentInvitations")

  assignedTickets Ticket[]
  knowledgeDocuments KnowledgeDocument[]

  @@index([organizationId])

  @@map("users")
}

model BusinessApiConfig {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @unique @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])

  baseUrl        String       // e.g. "https://api.theirbusiness.com"
  authType       ApiAuthType  // API_KEY, BEARER, BASIC
  authValue      String       // encrypted token/key they provide
  headerName     String?      // e.g. "x-api-key" if authType is API_KEY

  isVerified     Boolean      @default(false)  // did they pass our config test?
  lastVerifiedAt DateTime?

  testEndpoint   String?

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  toolDefinitions ToolDefinition[]

  @@map("business_api_configs")
}


model ToolDefinition {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String            @db.Uuid
  organization   Organization      @relation(fields: [organizationId], references: [id])

  apiConfigId    String            @db.Uuid
  apiConfig      BusinessApiConfig @relation(fields: [apiConfigId], references: [id])

  name           String       // e.g. "getOrderById"
  description    String       // what this tool does — the agent reads this to decide when to call it
  method         HttpMethod   // GET, POST, PUT, DELETE
  path           String       // e.g. "/orders/{orderId}"

  documentId String? @db.Uuid
  document   KnowledgeDocument? @relation(fields: [documentId], references: [id])

  parameters     Json         // { name, type, required, location: "path"|"query"|"body", description }[]
  responseSchema Json         // what the response looks like so agent can parse it

  isActive       Boolean      @default(true)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@map("tool_definitions")
}


model ApiKey {
  id              String       @id @default(uuid()) @db.Uuid

  organizationId  String       @db.Uuid
  organization    Organization @relation(fields: [organizationId], references: [id])

  keyHash         String @unique
  keyPrefix       String

  name            String

  allowedOrigins  String[]

  isActive        Boolean      @default(true)

  lastUsedAt      DateTime?

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  conversations   Conversation[]

  @@index([keyHash])

  @@map("api_keys")
}

model Customer {
  id              String       @id @default(uuid()) @db.Uuid

  organizationId  String       @db.Uuid
  organization    Organization @relation(fields: [organizationId], references: [id])

  externalId      String?
  email           String?
  name            String?

  metadata        Json         @default("{}")

  isAnonymous     Boolean      @default(true)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  conversations   Conversation[]
  csatRatings     CsatRating[]

  @@unique([organizationId, externalId])

  @@index([organizationId])

  @@map("customers")
}

model Conversation {
  id                  String               @id @default(uuid()) @db.Uuid

  organizationId      String               @db.Uuid
  organization        Organization         @relation(fields: [organizationId], references: [id])

  customerId          String               @db.Uuid
  customer            Customer             @relation(fields: [customerId], references: [id])

  apiKeyId            String               @db.Uuid
  apiKey              ApiKey               @relation(fields: [apiKeyId], references: [id])

  conversationStatus  ConversationStatus

  closedAt            DateTime?

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  messages            Message[]
  agentLogs           AgentLog[]
  ticket              Ticket?
  csatRating          CsatRating?
  analytics           ConversationAnalytics?

  @@index([organizationId])
  @@index([customerId])
  @@index([conversationStatus])

  @@map("conversations")
}

model Message {
  id              String       @id @default(uuid()) @db.Uuid

  conversationId  String       @db.Uuid
  conversation    Conversation @relation(fields: [conversationId], references: [id])

  role            MessageRole

  content         String

  tier            MessageTier?

  createdAt       DateTime     @default(now())

  @@index([conversationId])

  @@map("messages")
}

model AgentLog {
  id                String       @id @default(uuid()) @db.Uuid

  conversationId    String       @db.Uuid
  conversation      Conversation @relation(fields: [conversationId], references: [id])

  tier              AgentTier
  action            AgentAction

  input             String
  output            String

  confidenceScore   Float

  latencyMs         Int
  tokensUsed        Int

  createdAt         DateTime     @default(now())

  @@index([conversationId])

  @@map("agent_logs")
}

model Ticket {
  id                String       @id @default(uuid()) @db.Uuid

  conversationId    String       @unique @db.Uuid
  conversation      Conversation @relation(fields: [conversationId], references: [id])

  organizationId    String       @db.Uuid
  organization      Organization @relation(fields: [organizationId], references: [id])

  assignedToId      String?      @db.Uuid
  assignedTo        User?        @relation(fields: [assignedToId], references: [id])

  status            TicketStatus @default(OPEN)
  priority          TicketPriority @default(MEDIUM)

  resolutionNote    String?

  resolvedAt        DateTime?

  issueType          String?
  issueDescription   String?
  language           String?

  escalationReason   String?
  tiersVisited       AgentTier[]   // array of which tiers handled this
  knowledgeResults   Json          @default("[]")  // what RAG found
  agentAttempts      Int           @default(0)

  customerMessage    String?       // the triggering message

  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([organizationId])
  @@index([status])

  @@map("tickets")
}

model KnowledgeDocument {
  id              String                  @id @default(uuid()) @db.Uuid

  organizationId  String                  @db.Uuid
  organization    Organization            @relation(fields: [organizationId], references: [id])

  title           String

  type            KnowledgeDocumentType

  storagePath       String?

  status          KnowledgeDocumentStatus

  toolDefinitions ToolDefinition[]

  toolCount        Int   @default(0)
  activeToolCount  Int   @default(0)
  disabledToolCount Int  @default(0)

  metadata        Json                    @default("{}")

  createdById     String                  @db.Uuid
  createdBy       User                    @relation(fields: [createdById], references: [id])

  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  chunks          DocumentChunk[]

  @@index([organizationId])
  @@index([status])

  @@map("knowledge_documents")
}

model DocumentChunk {
  id              String              @id @default(uuid()) @db.Uuid

  documentId      String              @db.Uuid
  document        KnowledgeDocument   @relation(fields: [documentId], references: [id])

  organizationId  String              @db.Uuid
  organization    Organization        @relation(fields: [organizationId], references: [id])

  content         String

  embedding       Unsupported("vector(1536)")

  chunkIndex      Int

  metadata        Json                @default("{}")

  createdAt       DateTime            @default(now())

  @@index([documentId])
  @@index([organizationId])

  @@map("document_chunks")
}

model CsatRating {
  id              String          @id @default(uuid()) @db.Uuid

  conversationId  String          @unique @db.Uuid
  conversation    Conversation    @relation(fields: [conversationId], references: [id])

  organizationId  String          @db.Uuid
  organization    Organization    @relation(fields: [organizationId], references: [id])

  customerId      String          @db.Uuid
  customer        Customer        @relation(fields: [customerId], references: [id])

  score           Int

  comment         String?

  createdAt       DateTime        @default(now())

  @@index([organizationId])

  @@map("csat_ratings")
}

model ConversationAnalytics {
  id                    String          @id @default(uuid()) @db.Uuid

  conversationId        String          @unique @db.Uuid
  conversation          Conversation    @relation(fields: [conversationId], references: [id])

  organizationId        String          @db.Uuid
  organization          Organization    @relation(fields: [organizationId], references: [id])

  resolvedByTier        ResolutionTier

  totalMessages         Int

  firstResponseTimeMs   Int

  resolutionTimeMs      Int

  escalatedToTier2      Boolean         @default(false)

  escalatedToHuman      Boolean         @default(false)

  tokensUsed            Int

  csatScore             Int?

  inferredSentiment     Sentiment?

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([organizationId])

  @@map("conversation_analytics")
}

model Pricing {
  id                     String          @id @default(uuid()) @db.Uuid

  name                   String

  priceMonthly           Decimal         @db.Decimal(10, 2)

  maxConversations       Int?

  maxAgents              Int?

  maxKnowledgeDocuments  Int?

  features               Json            @default("{}")

  isActive               Boolean         @default(true)

  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  organizations          Organization[]
  payments               Payment[]

  @@map("pricing")
}

model Payment {
  id                 String        @id @default(uuid()) @db.Uuid

  organizationId     String        @db.Uuid
  organization       Organization  @relation(fields: [organizationId], references: [id])

  pricingId          String        @db.Uuid
  pricing            Pricing       @relation(fields: [pricingId], references: [id])

  amount             Decimal       @db.Decimal(10, 2)

  currency           String

  status             PaymentStatus

  paymentProvider    String

  providerPaymentId  String        @unique

  billingPeriodStart DateTime
  billingPeriodEnd   DateTime

  createdAt          DateTime      @default(now())

  @@index([organizationId])

  @@map("payments")
}

model Invitation {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @db.Uuid
  organization   Organization     @relation(fields: [organizationId], references: [id])

  email          String
  token          String           @unique
  role           Role             @default(SUPPORT_AGENT)

  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime
  acceptedAt     DateTime?

  invitedById    String           @db.Uuid
  invitedBy      User             @relation("SentInvitations", fields: [invitedById], references: [id])

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([token])
  @@index([organizationId])
  @@map("invitations")
}

enum Role {
  SUPER_ADMIN
  ORG_ADMIN
  SUPPORT_AGENT
}

enum ConversationStatus {
  ACTIVE
  ESCALATED
  CLOSED
}

enum MessageRole {
  CUSTOMER
  AI
  HUMAN_AGENT
}

enum AgentTier {
  ROUTER
  TIER1
  TIER2
}

enum AgentAction {
  RESOLVED
  ESCALATED_TO_TIER2
  ESCALATED_TO_HUMAN
  NO_MATCH
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum KnowledgeDocumentType {
  PDF
  URL
  TEXT
  DOCX
  CSV
  API_DOC
  SWAGGER_URL
}

enum KnowledgeDocumentStatus {
  PROCESSING
  READY
  FAILED
}

enum ResolutionTier {
  TIER1
  TIER2
  HUMAN
  UNRESOLVED
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum MessageTier {
  TIER1
  TIER2
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum ApiAuthType {
  API_KEY
  BEARER
  BASIC
}

enum HttpMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
}
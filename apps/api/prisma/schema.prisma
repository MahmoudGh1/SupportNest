generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id                    String                  @id @default(uuid()) @db.Uuid
  name                  String
  slug                  String                  @unique
  email                 String
  widgetSecret          String
  widgetConfig          Json                    @default("{}")
  planId                String                  @db.Uuid
  isActive              Boolean                 @default(true)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  apiKeys               ApiKey[]
  businessApiConfig     BusinessApiConfig?
  conversationAnalytics ConversationAnalytics[]
  conversations         Conversation[]
  csatRatings           CsatRating[]
  customers             Customer[]
  documentChunks        DocumentChunk[]
  invitations           Invitation[]
  knowledgeDocuments    KnowledgeDocument[]
  plan                  Pricing                 @relation(fields: [planId], references: [id])
  payments              Payment[]
  reports               Report[]
  tickets               Ticket[]
  toolDefinitions       ToolDefinition[]
  users                 User[]
  

  @@map("organizations")
}

model User {
  id                 String              @id @default(uuid()) @db.Uuid
  organizationId     String?             @db.Uuid
  email              String              @unique
  passwordHash       String
  role               Role
  firstName          String
  lastName           String
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  sentInvitations    Invitation[]        @relation("SentInvitations")
  knowledgeDocuments KnowledgeDocument[]
  assignedTickets    Ticket[]
  organization       Organization?       @relation(fields: [organizationId], references: [id])
  isEmailVerified    Boolean   @default(false)
  emailVerifiedAt    DateTime?
  emailVerifications EmailVerification[]
  passwordResets     PasswordReset[]

  @@index([organizationId])
  @@map("users")
}

model BusinessApiConfig {
  id              String           @id @default(uuid()) @db.Uuid
  organizationId  String           @unique @db.Uuid
  baseUrl         String
  authType        ApiAuthType
  authValue       String
  headerName      String?
  isVerified      Boolean          @default(false)
  lastVerifiedAt  DateTime?
  testEndpoint    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  organization    Organization     @relation(fields: [organizationId], references: [id])
  toolDefinitions ToolDefinition[]

  @@map("business_api_configs")
}

model ToolDefinition {
  id                  String             @id @default(uuid()) @db.Uuid
  organizationId      String             @db.Uuid
  apiConfigId         String             @db.Uuid
  name                String
  description         String
  method              HttpMethod
  path                String
  documentId          String?            @db.Uuid
  parameters          Json
  responseSchema      Json
  isActive            Boolean            @default(true)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  apiConfig           BusinessApiConfig  @relation(fields: [apiConfigId], references: [id])
  knowledge_documents KnowledgeDocument? @relation(fields: [documentId], references: [id])
  organization        Organization       @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("tool_definitions")
}

model ApiKey {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @db.Uuid
  keyHash        String         @unique
  keyPrefix      String
  name           String
  allowedOrigins String[]
  isActive       Boolean        @default(true)
  lastUsedAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id])
  conversations  Conversation[]

  @@index([keyHash])
  @@map("api_keys")
}

model Customer {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @db.Uuid
  externalId     String?
  email          String?
  name           String?
  metadata       Json           @default("{}")
  isAnonymous    Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  conversations  Conversation[]
  csatRatings    CsatRating[]
  organization   Organization   @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, externalId])
  @@index([organizationId])
  @@map("customers")
}

model Conversation {
  id                 String                 @id @default(uuid()) @db.Uuid
  organizationId     String                 @db.Uuid
  customerId         String                 @db.Uuid
  apiKeyId           String                 @db.Uuid
  conversationStatus ConversationStatus
  closedAt           DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  agentLogs          AgentLog[]
  analytics          ConversationAnalytics?
  apiKey             ApiKey                 @relation(fields: [apiKeyId], references: [id])
  customer           Customer               @relation(fields: [customerId], references: [id])
  organization       Organization           @relation(fields: [organizationId], references: [id])
  csatRating         CsatRating?
  messages           Message[]
  reports            Report[]
  ticket             Ticket?

  @@index([organizationId])
  @@index([customerId])
  @@index([conversationStatus])
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @db.Uuid
  role           MessageRole
  content        String
  tier           MessageTier?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
  @@map("messages")
}

model AgentLog {
  id              String       @id @default(uuid()) @db.Uuid
  conversationId  String       @db.Uuid
  tier            AgentTier
  action          AgentAction
  input           String
  output          String
  confidenceScore Float
  latencyMs       Int
  tokensUsed      Int
  createdAt       DateTime     @default(now())
  conversation    Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
  @@map("agent_logs")
}

model Ticket {
  id               String         @id @default(uuid()) @db.Uuid
  conversationId   String         @unique @db.Uuid
  organizationId   String         @db.Uuid
  assignedToId     String?        @db.Uuid
  status           TicketStatus   @default(OPEN)
  priority         TicketPriority @default(MEDIUM)
  resolutionNote   String?
  resolvedAt       DateTime?
  issueType        String?
  issueDescription String?
  language         String?
  escalationReason String?
  tiersVisited     AgentTier[]
  knowledgeResults Json           @default("[]")
  agentAttempts    Int            @default(0)
  customerMessage  String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  assignedTo       User?          @relation(fields: [assignedToId], references: [id])
  conversation     Conversation   @relation(fields: [conversationId], references: [id])
  organization     Organization   @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([status])
  @@map("tickets")
}

model KnowledgeDocument {
  id                String                  @id @default(uuid()) @db.Uuid
  organizationId    String                  @db.Uuid
  title             String
  type              KnowledgeDocumentType
  storagePath       String?
  status            KnowledgeDocumentStatus
  toolCount         Int                     @default(0)
  activeToolCount   Int                     @default(0)
  disabledToolCount Int                     @default(0)
  metadata          Json                    @default("{}")
  createdById       String                  @db.Uuid
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  chunks            DocumentChunk[]
  createdBy         User                    @relation(fields: [createdById], references: [id])
  organization      Organization            @relation(fields: [organizationId], references: [id])
  tool_definitions  ToolDefinition[]

  @@index([organizationId])
  @@index([status])
  @@map("knowledge_documents")
}

model DocumentChunk {
  id             String                @id @default(uuid()) @db.Uuid
  documentId     String                @db.Uuid
  organizationId String                @db.Uuid
  content        String
  embedding      Unsupported("vector(1536)")
  chunkIndex     Int
  metadata       Json                  @default("{}")
  createdAt      DateTime              @default(now())
  document       KnowledgeDocument     @relation(fields: [documentId], references: [id])
  organization   Organization          @relation(fields: [organizationId], references: [id])

  @@index([documentId])
  @@index([organizationId])
  @@map("document_chunks")
}

model CsatRating {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @unique @db.Uuid
  organizationId String       @db.Uuid
  customerId     String       @db.Uuid
  score          Int
  comment        String?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  customer       Customer     @relation(fields: [customerId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("csat_ratings")
}

model ConversationAnalytics {
  id                  String         @id @default(uuid()) @db.Uuid
  conversationId      String         @unique @db.Uuid
  organizationId      String         @db.Uuid
  resolvedByTier      ResolutionTier
  totalMessages       Int
  firstResponseTimeMs Int
  resolutionTimeMs    Int
  escalatedToTier2    Boolean        @default(false)
  escalatedToHuman    Boolean        @default(false)
  tokensUsed          Int
  csatScore           Int?
  inferredSentiment   Sentiment?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  conversation        Conversation   @relation(fields: [conversationId], references: [id])
  organization        Organization   @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("conversation_analytics")
}

model Pricing {
  id                    String         @id @default(uuid()) @db.Uuid
  name                  String
  priceMonthly          Decimal        @db.Decimal(10, 2)
  maxConversations      Int?
  maxAgents             Int?
  maxKnowledgeDocuments Int?
  features              Json           @default("{}")
  isActive              Boolean        @default(true)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  organizations         Organization[]
  payments              Payment[]

  @@map("pricing")
}

model Payment {
  id                 String        @id @default(uuid()) @db.Uuid
  organizationId     String        @db.Uuid
  pricingId          String        @db.Uuid
  amount             Decimal       @db.Decimal(10, 2)
  currency           String
  status             PaymentStatus
  paymentProvider    String
  providerPaymentId  String        @unique
  billingPeriodStart DateTime
  billingPeriodEnd   DateTime
  createdAt          DateTime      @default(now())
  organization       Organization  @relation(fields: [organizationId], references: [id])
  pricing            Pricing       @relation(fields: [pricingId], references: [id])

  @@index([organizationId])
  @@map("payments")
}

model Invitation {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @db.Uuid
  email          String
  token          String           @unique
  role           Role             @default(SUPPORT_AGENT)
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime
  acceptedAt     DateTime?
  invitedById    String           @db.Uuid
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  invitedBy      User             @relation("SentInvitations", fields: [invitedById], references: [id])
  organization   Organization     @relation(fields: [organizationId], references: [id])

  @@index([token])
  @@index([organizationId])
  @@map("invitations")
}

model Report {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  conversationId String       @db.Uuid
  summary        String
  issueType      String
  resolution     String
  language       String
  sentiment      String
  tiersVisited   AgentTier[]
  wasEscalated   Boolean      @default(false)
  resolvedByAi   Boolean      @default(true)
  tokensUsed     Int          @default(0)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("reports")
}

model EmailVerification {
    id        String   @id @default(uuid()) @db.Uuid
    userId    String   @db.Uuid
    email     String
    code      String
    expiresAt DateTime
    createdAt DateTime @default(now())
    user      User     @relation(fields: [userId], references: [id])

    @@index([userId])
    @@index([email])
    @@map("email_verifications")
}

model PasswordReset {
    id        String   @id @default(uuid()) @db.Uuid
    userId    String   @db.Uuid
    token     String   @unique
    expiresAt DateTime
    createdAt DateTime @default(now())
    used      Boolean  @default(false)
    user      User     @relation(fields: [userId], references: [id])

    @@index([token])
    @@map("password_resets")
}

enum Role {
  SUPER_ADMIN
  ORG_ADMIN
  SUPPORT_AGENT
}

enum ConversationStatus {
  ACTIVE
  ESCALATED
  CLOSED
}

enum MessageRole {
  CUSTOMER
  AI
  HUMAN_AGENT
}

enum AgentTier {
  ROUTER
  TIER0
  TIER1
  TIER2
}

enum AgentAction {
  RESOLVED
  ESCALATED_TO_TIER0
  ESCALATED_TO_TIER1
  ESCALATED_TO_TIER2
  ESCALATED_TO_HUMAN
  REJECTED_OUTPUT
  NO_MATCH
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum KnowledgeDocumentType {
  PDF
  URL
  TEXT
  DOCX
  CSV
  API_DOC
  SWAGGER_URL
}

enum KnowledgeDocumentStatus {
  PROCESSING
  READY
  FAILED
}

enum ResolutionTier {
  TIER0
  TIER1
  TIER2
  HUMAN
  UNRESOLVED
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum MessageTier {
  TIER0
  TIER1
  TIER2
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum ApiAuthType {
  API_KEY
  BEARER
  BASIC
}

enum HttpMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
}
